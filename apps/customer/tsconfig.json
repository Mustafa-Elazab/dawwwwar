{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "jsx": "react-native",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "paths": {
      "@/*": ["src/*"],
      "@dawwar/types": ["../../packages/types/src"],
      "@dawwar/types/*": ["../../packages/types/src/*"],
      "@dawwar/theme": ["../../packages/theme/src"],
      "@dawwar/theme/*": ["../../packages/theme/src/*"],
      "@dawwar/i18n": ["../../packages/i18n/src"],
      "@dawwar/i18n/*": ["../../packages/i18n/src/*"],
      "@dawwar/mocks": ["../../packages/mocks/src"],
      "@dawwar/mocks/*": ["../../packages/mocks/src/*"],
      "@dawwar/ui": ["../../packages/ui/src"],
      "@dawwar/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src", "index.js"]
}
