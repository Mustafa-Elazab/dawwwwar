# Server
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=dawwar
DB_PASSWORD=your_password_here
DB_DATABASE=dawwar_db
DB_SYNC=true
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# OTP
OTP_SANDBOX=true
OTP_SANDBOX_CODE=123456
OTP_EXPIRES_SECONDS=120

# Twilio (Phase 2 Task 03)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS S3 / Cloudflare R2 (Phase 3 Task 03)
# For AWS S3: leave S3_ENDPOINT empty
# For Cloudflare R2: S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=
AWS_REGION=eu-central-1
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
UPLOAD_PUBLIC_BASE_URL=

# Firebase (Phase 2 Task 09)
FIREBASE_PROJECT_ID=
